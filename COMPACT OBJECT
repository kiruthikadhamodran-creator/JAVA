
var compactObject = function(obj) {
    if (Array.isArray(obj)) {
        const result = [];
        
        for (let item of obj) {
            if (Boolean(item)) {
                if (typeof item === "object" && item !== null) {
                    result.push(compactObject(item));
                } else {
                    result.push(item);
                }
            }
        }
        
        return result;
    }

    if (typeof obj === "object" && obj !== null) {
        const result = {};
        
        for (let key in obj) {
            const value = obj[key];
            
            if (Boolean(value)) {
                if (typeof value === "object") {
                    result[key] = compactObject(value);
                } else {
                    result[key] = value;
                }
            }
        }
        
        return result;
    }

    return obj;
};
